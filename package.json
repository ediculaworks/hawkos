{
  "name": "hawk-os",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": ["apps/*", "packages/*", "packages/modules/*"],
  "scripts": {
    "dev": "bun run predev && turbo dev",
    "predev": "rm -f apps/web/.next/dev/lock",
    "dev:web": "rm -f apps/web/.next/dev/lock && bun run --cwd apps/web dev",
    "dev:agent": "bun run --env-file=.env apps/agent/src/index.ts",
    "build": "turbo build",
    "build:web": "bun run --cwd apps/web build",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config apps/web/playwright.config.ts",
    "clean": "turbo clean && rm -rf node_modules",
    "agent": "bun run --env-file=.env apps/agent/src/index.ts",
    "db:migrate": "bun run --env-file=.env scripts/apply-migrations.ts",
    "db:types": "echo 'Type generation: run kysely-codegen or manually update packages/db/types/database.ts'",
    "setup": "bun scripts/setup.ts",
    "prepare": "git config core.hooksPath .husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "turbo": "^2.8.17",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1016.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8",
    "react-hot-toast": "^2.6.0",
    "web-streams-polyfill": "^3.3.3",
    "zod": "^4.3.6"
  }
}
