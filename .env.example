# =============================================================================
# Hawk OS — Environment Variables
# Copie para .env e preencha os valores reais. NUNCA commite o .env.
# =============================================================================

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Discord
DISCORD_BOT_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-client-id
DISCORD_GUILD_ID=your-guild-id
DISCORD_CHANNEL_ID=your-hawk-channel-id
DISCORD_AUTHORIZED_USER_ID=your-discord-user-id

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_MAX_TOKENS=4096

# Google Calendar
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Cloudflare R2 (backups)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET=hawk-os-backups

# App
NODE_ENV=development
APP_URL=http://localhost:3000

# Frontend (prefixo NEXT_PUBLIC_ = exposto ao browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Agent API (Mission Control)
AGENT_API_PORT=3001
AGENT_API_SECRET=your-secret-for-web-auth
# Same value as AGENT_API_SECRET — exposed to browser for direct agent API calls
NEXT_PUBLIC_AGENT_API_TOKEN=your-secret-for-web-auth

# Voice Transcription (choose one)
# Groq Whisper is free and fast — recommended
GROQ_API_KEY=your-groq-api-key
# Or use OpenAI Whisper directly
# OPENAI_API_KEY=your-openai-api-key

# Discord Multi-Agent Channel Routing
# Format: channelId:agentTemplateId,channelId:agentTemplateId
# Channels not listed use default Hawk agent
# DISCORD_CHANNEL_MAP=123456:cfo-uuid,789012:coach-uuid

# GitHub Extension (OAuth App for full integration)
GITHUB_USERNAME=your-github-username
# GITHUB_TOKEN=ghp_your-personal-access-token
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret

# ClickUp Extension
CLICKUP_CLIENT_ID=your-clickup-client-id
CLICKUP_CLIENT_SECRET=your-clickup-client-secret

# Job Monitor (daily job search automation)
# Comma-separated keywords
# JOB_MONITOR_KEYWORDS=developer,engenheiro de software,médico
# JOB_MONITOR_LOCATION=São Paulo

# Heartbeat / Proactivity
# Profile: guardian (every 30min), companion (4x/day), silent (disabled)
HEARTBEAT_PROFILE=companion
# Active hours in BRT (heartbeat won't run outside this window)
HEARTBEAT_ACTIVE_HOURS=08:00-22:00

# =============================================================================
# ADMIN SUPABASE (Plataforma Multi-Tenant)
# Projeto central que gerencia todos os tenants
# =============================================================================

# Admin Supabase (plataforma)
ADMIN_SUPABASE_URL=https://your-admin-project.supabase.co
NEXT_PUBLIC_ADMIN_SUPABASE_URL=https://your-admin-project.supabase.co
ADMIN_SUPABASE_ANON_KEY=your-admin-anon-key
ADMIN_SUPABASE_SERVICE_KEY=your-admin-service-role-key

# Admin Supabase DB Password (para bun scripts/setup-admin.ts)
# Settings → Database → Connection info → Database password
# ADMIN_SUPABASE_DB_PASSWORD=your-db-password

# Supabase Personal Access Token (para migration runner do onboarding)
# Obtenha em: https://app.supabase.com/account/tokens
# Necessário para o onboarding aplicar migrações automaticamente
SUPABASE_ACCESS_TOKEN=sbp_your-personal-access-token

# Agent Slot (para agents em modo multi-tenant)
# AGENT_SLOT=ten1  # ou ten2, ten3, ..., ten6

# Onboarding master password — bypasses account password check in reset-account
# Allows deleting any tenant account even if the original password was forgotten
# Generate a strong random password: openssl rand -hex 16
ONBOARDING_MASTER_PASSWORD=your-master-password
