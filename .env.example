# =============================================================================
# Hawk OS — Environment Variables
# Copie para .env e preencha os valores reais. NUNCA commite o .env.
# =============================================================================

# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Direct connection (for migrations, admin tasks)
DATABASE_URL=postgres://hawkos:your-password@localhost:5432/hawkos
# Pooled connection via PgBouncer (for application)
DATABASE_POOL_URL=postgres://hawkos:your-password@localhost:6432/hawkos

# PostgreSQL Docker credentials
POSTGRES_USER=hawkos
POSTGRES_PASSWORD=your-secure-password

# ── Authentication ──────────────────────────────────────────────────────────
# Secret for signing JWTs (generate: openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-at-least-32-chars

# Master key for encrypting tenant secrets (Discord tokens, API keys)
# Can be the same as JWT_SECRET or separate
ADMIN_MASTER_KEY=your-admin-master-key

# ── Tenant Schema (single-tenant mode only) ─────────────────────────────────
# When running without multi-tenant, set the schema name directly
# TENANT_SCHEMA=public

# Discord
DISCORD_BOT_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-client-id
DISCORD_GUILD_ID=your-guild-id
DISCORD_CHANNEL_ID=your-hawk-channel-id
DISCORD_AUTHORIZED_USER_ID=your-discord-user-id

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_MAX_TOKENS=4096

# Model Tiers (smart routing by query complexity)
# MODEL_TIER_SIMPLE=nvidia/nemotron-3-nano-30b-a3b:free
# MODEL_TIER_DEFAULT=qwen/qwen3.6-plus:free
# MODEL_TIER_COMPLEX=qwen/qwen3.6-plus:free
# MODEL_DAILY_BUDGET_USD=5.00

# Ollama (local inference — optional)
# When set, simple tier (greetings, CRUD) uses qwen3:4b locally; workers also go local.
# Model downloaded automatically on first request (~2.5GB stored in Docker volume).
# Recommended for VPS with >=4GB RAM available. CPU inference: ~2-4s for short messages.
# Options: qwen3:4b (best, 3.5GB), qwen3:1.7b (faster, 2GB), ministral-3:3b (tool calling, 4GB)
# OLLAMA_BASE_URL=http://ollama:11434/v1
# OLLAMA_WORKER_MODEL=qwen3:4b

# Worker model for background tasks (dedup, extraction, summarization)
# MEMORY_WORKER_MODEL=nvidia/nemotron-nano-9b-v2:free
# DEDUP_WORKER_MODEL=nvidia/nemotron-nano-9b-v2:free

# Google Calendar
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Cloudflare R2 (backups)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET=hawk-os-backups

# App
NODE_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Domain (used by Caddy for automatic HTTPS via Let's Encrypt)
# Leave empty for local dev. Set to your domain for production.
# DOMAIN=hawk.meudominio.com

# Agent API (Mission Control)
AGENT_API_PORT=3001
AGENT_API_SECRET=your-secret-for-web-auth
NEXT_PUBLIC_AGENT_API_TOKEN=your-secret-for-web-auth

# Voice Transcription
GROQ_API_KEY=your-groq-api-key

# GitHub Extension
GITHUB_USERNAME=your-github-username
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret

# ClickUp Extension
CLICKUP_CLIENT_ID=your-clickup-client-id
CLICKUP_CLIENT_SECRET=your-clickup-client-secret

# Heartbeat / Proactivity
HEARTBEAT_PROFILE=companion
HEARTBEAT_ACTIVE_HOURS=08:00-22:00

# Agent Slot (multi-tenant mode — each agent instance serves one tenant)
# AGENT_SLOT=ten1

# Onboarding master password (for admin account reset)
ONBOARDING_MASTER_PASSWORD=your-master-password
