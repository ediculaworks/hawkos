# Hawk OS — Caddy Reverse Proxy
#
# Modo 1: Com dominio (HTTPS automatico via Let's Encrypt)
#   DOMAIN=hawk.meudominio.com → HTTPS com certificado real
#
# Modo 2: Sem dominio (HTTP direto, para dev/testes)
#   DOMAIN= (vazio) → HTTP na porta 80, sem TLS
#
# A variavel {$DOMAIN} e injetada pelo docker-compose via environment.

{$DOMAIN:localhost} {
	# Agent WebSocket + API proxies (must be before the catch-all)
	handle /ws/ten1* {
		reverse_proxy agent-ten1:3001
	}
	handle /ws/ten2* {
		reverse_proxy agent-ten2:3001
	}
	handle /ws/ten3* {
		reverse_proxy agent-ten3:3001
	}
	handle /ws/ten4* {
		reverse_proxy agent-ten4:3001
	}
	handle /ws/ten5* {
		reverse_proxy agent-ten5:3001
	}
	handle /ws/ten6* {
		reverse_proxy agent-ten6:3001
	}

	# Agent health/API endpoints
	handle /agent/ten1/* {
		uri strip_prefix /agent/ten1
		reverse_proxy agent-ten1:3001
	}
	handle /agent/ten2/* {
		uri strip_prefix /agent/ten2
		reverse_proxy agent-ten2:3001
	}
	handle /agent/ten3/* {
		uri strip_prefix /agent/ten3
		reverse_proxy agent-ten3:3001
	}
	handle /agent/ten4/* {
		uri strip_prefix /agent/ten4
		reverse_proxy agent-ten4:3001
	}
	handle /agent/ten5/* {
		uri strip_prefix /agent/ten5
		reverse_proxy agent-ten5:3001
	}
	handle /agent/ten6/* {
		uri strip_prefix /agent/ten6
		reverse_proxy agent-ten6:3001
	}

	# Next.js web app (catch-all)
	reverse_proxy web:3000

	encode gzip zstd

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	log {
		output file /data/access.log {
			roll_size 10mb
			roll_keep 3
		}
	}
}
