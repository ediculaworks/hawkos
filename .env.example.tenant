# ── Hawk OS — Tenant Agent Environment ───────────────────────────────────────
# Copy this file as .env.<tenant-slug> and fill in the values.
# Each agent container gets its own .env file with its own credentials.

# Supabase (tenant's own project)
SUPABASE_URL=https://your-tenant-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Discord (tenant's own bot)
DISCORD_BOT_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-client-id
DISCORD_GUILD_ID=your-guild-id
DISCORD_CHANNEL_ID=your-channel-id
DISCORD_CHANNEL_GERAL=your-channel-id
DISCORD_AUTHORIZED_USER_ID=your-discord-user-id

# AI Provider
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_MAX_TOKENS=4096

# Agent API (internal — port should match agentApiPort in tenants.json)
AGENT_API_PORT=3001
AGENT_API_SECRET=generate-a-random-secret

# Optional
NODE_ENV=production
HEARTBEAT_PROFILE=companion
HEARTBEAT_ACTIVE_HOURS=08:00-22:00
