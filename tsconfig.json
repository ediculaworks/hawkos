{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@hawk/finances": ["packages/modules/finances"],
      "@hawk/calendar": ["packages/modules/calendar"],
      "@hawk/health": ["packages/modules/health"],
      "@hawk/people": ["packages/modules/people"],
      "@hawk/career": ["packages/modules/career"],
      "@hawk/objectives": ["packages/modules/objectives"],
      "@hawk/knowledge": ["packages/modules/knowledge"],
      "@hawk/routine": ["packages/modules/routine"],
      "@hawk/assets": ["packages/modules/assets"],
      "@hawk/entertainment": ["packages/modules/entertainment"],
      "@hawk/legal": ["packages/modules/legal"],
      "@hawk/social": ["packages/modules/social"],
      "@hawk/spirituality": ["packages/modules/spirituality"],
      "@hawk/housing": ["packages/modules/housing"],
      "@hawk/security": ["packages/modules/security"],
      "@hawk/journal": ["packages/modules/journal"],
      "@hawk/db": ["packages/db"],
      "@hawk/context-engine": ["packages/context-engine"],
      "@hawk/shared": ["packages/shared"],
      "@hawk/extensions": ["packages/extensions"],
      "@hawk/extensions/*": ["packages/extensions/*"]
    }
  },
  "include": ["packages/**/*.ts", "apps/agent/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/.next", ".turbo", "**/node_modules", "resources"]
}
